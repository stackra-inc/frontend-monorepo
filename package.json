{
  "name": "stackra-inc-frontend-monorepo",
  "version": "0.0.0",
  "description": "Stackra frontend monorepo — React/Vite/Electron apps and shared TypeScript packages.",
  "private": true,
  "homepage": "https://github.com/stackra-inc/frontend-monorepo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stackra-inc/frontend-monorepo.git"
  },
  "bugs": {
    "url": "https://github.com/stackra-inc/frontend-monorepo/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://stackra.com"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/ab/*",
    "packages/ab/vite/*",
    "packages/acd/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:packages": "turbo run build --filter='./packages/*'",
    "build:apps": "turbo run build --filter='./apps/*'",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css,js,mjs,cjs}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,css,js,mjs,cjs}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "clean": "./scripts/cleanup.sh build",
    "clean:all": "./scripts/cleanup.sh all",
    "clean:deps": "./scripts/cleanup.sh deps",
    "clean:cache": "./scripts/cleanup.sh cache",
    "reset": "npm run clean:all && npm install",
    "prepare": "husky",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "release": "turbo run build --filter='./packages/*' && changeset publish",
    "validate": "npm run lint && npm run check-types && npm run build",
    "graph": "turbo run build --graph=dependency-graph.html",
    "audit": "npm audit",
    "make:package": "./scripts/cli/create-package.sh",
    "sync:configs": "./scripts/cli/cli.sh",
    "update:deps": "npx npm-check-updates -u --peer --dep dev,prod,peer --root --workspaces",
    "update:interactive": "npx npm-check-updates -u --peer --dep dev,prod,peer --root --workspaces --interactive"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@stackra/tsup-config": "^1.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "only-allow": "^1.2.2",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tsup": "^8.5.1",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "pnpm": {
    "overrides": {
      "typescript": "^6.0.3",
      "tsup": "^8.5.1",
      "vitest": "^4.1.2",
      "eslint": "^10.1.0",
      "prettier": "^3.8.3",
      "@stackra/typescript-config": "^1.0.4",
      "@stackra/tsup-config": "^1.0.4",
      "@stackra/eslint-config": "^1.0.6",
      "@stackra/prettier-config": "^1.0.3"
    },
    "onlyBuiltDependencies": [
      "@swc/core",
      "@tailwindcss/oxide",
      "electron",
      "electron-winstaller",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.2"
}
