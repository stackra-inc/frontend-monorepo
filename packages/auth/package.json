{
  "name": "@stakra/react-auth",
  "version": "1.0.0",
  "description": "Authentication, session management, and security for React applications",
  "license": "MIT",
  "author": {
    "name": "Stakra L.L.C",
    "email": "dev@stakra.com",
    "url": "https://github.com/stakra"
  },
  "keywords": [
    "react",
    "auth",
    "authentication",
    "session",
    "security",
    "hooks",
    "login",
    "oauth"
  ],
  "type": "module",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist node_modules/.cache",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@stakra/ts-events": "workspace:^",
    "@stakra/ts-http": "workspace:^",
    "@nesvel/eslint-config": "^1.0.5",
    "@nesvel/prettier-config": "^1.0.3",
    "@nesvel/tsup-config": "^1.0.3",
    "@nesvel/typescript-config": "^1.0.4",
    "@tanstack/react-query": "^5.96.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "eslint": "10.2.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@stakra/ts-container": "workspace:*",
    "@stakra/ts-events": "workspace:*",
    "@stakra/ts-http": "workspace:*",
    "@stakra/ts-cache": "workspace:*",
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependenciesMeta": {
    "@stakra/ts-container": {
      "optional": false
    },
    "@stakra/ts-http": {
      "optional": false
    },
    "@stakra/ts-events": {
      "optional": true
    },
    "@stakra/ts-cache": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": false
    },
    "reflect-metadata": {
      "optional": false
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "packageManager": "pnpm@10.33.0"
}
