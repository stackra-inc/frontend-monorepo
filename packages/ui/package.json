{
  "name": "@repo/ui",
  "version": "0.1.0",
  "description": "Shared React component library for the frontend-monorepo.",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/your-org/frontend-monorepo/tree/main/packages/ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/frontend-monorepo.git",
    "directory": "packages/ui"
  },
  "license": "MIT",
  "keywords": ["react", "ui", "components", "design-system"],
  "sideEffects": false,
  "exports": {
    "./*": "./src/*.tsx"
  },
  "scripts": {
    "build":            "tsc --build",
    "dev":              "tsc --build --watch",
    "lint":             "eslint . --max-warnings 0",
    "lint:fix":         "eslint . --fix",
    "check-types":      "tsc --noEmit",
    "clean":            "rm -rf dist .turbo tsconfig.tsbuildinfo",
    "generate:component":"turbo gen react-component"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "eslint": "^9.39.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  }
}
