{
  "name": "@pixielity/react-ui",
  "version": "0.1.0",
  "description": "Shared React component library for the Pixielity frontend monorepo.",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/pixielity-inc/frontend-monorepo/tree/main/packages/ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pixielity-inc/frontend-monorepo.git",
    "directory": "packages/ui"
  },
  "license": "MIT",
  "keywords": [
    "react",
    "ui",
    "components",
    "design-system"
  ],
  "sideEffects": false,
  "exports": {
    "./*": "./src/*.tsx"
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "check-types": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf dist .turbo tsconfig.tsbuildinfo",
    "clean:all": "rm -rf dist .turbo tsconfig.tsbuildinfo node_modules",
    "upgrade": "pnpm update --latest",
    "generate:component": "turbo gen react-component"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@pixielity/eslint-config": "workspace:*",
    "@pixielity/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "eslint": "^9.39.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=10"
  },
  "author": {
    "name": "Pixielity Team",
    "email": "dev@pixielity.com",
    "url": "https://pixielity.com"
  },
  "bugs": {
    "url": "https://github.com/pixielity-inc/frontend-monorepo/issues"
  }
}
