{
  "name": "@stackra-inc/ts-logger",
  "version": "1.1.2",
  "description": "Flexible logging system with multiple formatters and transporters for React",
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://github.com/stackra-inc"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stackra-inc/react-logger.git",
    "directory": "packages/logger"
  },
  "bugs": {
    "url": "https://github.com/stackra-inc/react-logger/issues"
  },
  "homepage": "https://github.com/stackra-inc/react-logger#readme",
  "keywords": [
    "react",
    "logger",
    "logging",
    "console",
    "transport",
    "formatter",
    "dependency-injection",
    "di"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "config",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist node_modules/.cache",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm publish --access public --no-git-checks"
  },
  "peerDependencies": {
    "@stackra-inc/ts-container": "^2.0.4",
    "@stackra-inc/ts-support": "workspace:*",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@stackra-inc/ts-container": {
      "optional": false
    },
    "@stackra-inc/ts-support": {
      "optional": false
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@stackra-inc/ts-support": "workspace:*",
    "@stackra-inc/ts-container": "^2.0.4",
    "@eslint/js": "10.0.1",
    "@nesvel/eslint-config": "^1.0.5",
    "@nesvel/prettier-config": "^1.0.3",
    "@nesvel/tsup-config": "^1.0.3",
    "@nesvel/typescript-config": "^1.0.4",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@vitest/ui": "^4.1.2",
    "eslint": "10.2.0",
    "eslint-plugin-turbo": "^2.9.4",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "sideEffects": false,
  "packageManager": "pnpm@10.33.0"
}
