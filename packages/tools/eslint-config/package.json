{
  "name": "@stackra/eslint-config",
  "version": "1.0.9",
  "description": "Shared ESLint configuration presets for Stackra packages",
  "private": false,
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://github.com/stackra-inc"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "src",
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist node_modules/.cache",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm publish --access public --no-git-checks",
    "prepare": "husky"
  },
  "keywords": [
    "eslint",
    "config",
    "linting",
    "preset",
    "stackra"
  ],
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@darraghor/eslint-plugin-nestjs-typed": "^7.1.31",
    "@eslint/js": "^9.28.0",
    "@next/eslint-plugin-next": "^16.2.4",
    "@stackra/tsup-config": "^1.0.9",
    "@stackra/typescript-config": "^1.0.10",
    "@types/node": "^25.6.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-only-warn": "^1.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-turbo": "^2.9.6",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "eslint": ">=9.39.4",
    "typescript": ">=6.0.3"
  },
  "engines": {
    "node": ">=22.22.2",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.2",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "homepage": "https://github.com/stackra-inc/eslint-config#readme",
  "bugs": {
    "url": "https://github.com/stackra-inc/eslint-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stackra-inc/eslint-config.git"
  },
  "dependencies": {
    "@babel/preset-typescript": "^7.28.5"
  },
  "module": "./dist/index.js",
  "stackra": {
    "publish": {
      "config": {
        "source": "config/",
        "destination": "src/config/",
        "description": "ESLint linting configuration"
      },
      "steering": {
        "source": ".kiro/steering/",
        "destination": ".kiro/steering/{module}/",
        "description": "Kiro AI steering files for linting"
      },
      "hooks": {
        "source": ".kiro/hooks/",
        "destination": ".kiro/hooks/",
        "description": "Kiro hooks"
      }
    }
  }
}
