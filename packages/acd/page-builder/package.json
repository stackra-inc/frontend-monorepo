{
  "name": "@stackra/react-page-builder",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "description": "Visual page editor with drag-and-drop canvas, component palette, property editor, and SDUI integration",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "check-types": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm publish --access public --no-git-checks"
  },
  "peerDependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "@stackra/ts-container": "^2.0.10",
    "@stackra/ts-support": "^2.5.7",
    "@stackra/ts-http": "^1.0.0",
    "@stackra/react-sdui": "workspace:*",
    "@heroui/react": "^3.0.3",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependenciesMeta": {
    "@stackra/ts-container": {
      "optional": false
    },
    "@stackra/ts-support": {
      "optional": false
    },
    "@stackra/ts-http": {
      "optional": false
    },
    "@stackra/react-sdui": {
      "optional": false
    },
    "@heroui/react": {
      "optional": false
    },
    "reflect-metadata": {
      "optional": false
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "fast-check": "^4.7.0",
    "@testing-library/react": "^16.3.2",
    "eslint": "10.2.1",
    "prettier": "^3.8.3",
    "@stackra/typescript-config": "^1.0.5",
    "@stackra/tsup-config": "^1.0.4",
    "@stackra/eslint-config": "^1.0.6",
    "@stackra/prettier-config": "^1.0.4",
    "@vitest/ui": "^4.1.5",
    "jsdom": "^29.1.0",
    "typescript-eslint": "^8.59.0"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "packageManager": "pnpm@10.33.0"
}
