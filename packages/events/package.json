{
  "name": "@stackra/ts-events",
  "version": "0.2.0",
  "description": "Laravel-style event dispatcher for TypeScript — pub/sub with wildcard listeners, subscribers, decorators, multiple drivers (memory, redis, null), and RxJS streaming.",
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://github.com/stackra-inc"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stackra-inc/frontend-monorepo.git",
    "directory": "packages/events"
  },
  "keywords": [
    "events",
    "event-dispatcher",
    "pub-sub",
    "laravel",
    "rxjs",
    "decorators",
    "dependency-injection",
    "typescript"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "config",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist node_modules/.cache",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm publish --access public --no-git-checks"
  },
  "dependencies": {
    "rxjs": "^7.8.1"
  },
  "peerDependencies": {
    "@stackra/ts-container": "^2.0.4",
    "@stackra/ts-support": "workspace:*",
    "@stackra/ts-redis": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@stackra/ts-container": {
      "optional": false
    },
    "@stackra/ts-support": {
      "optional": false
    },
    "reflect-metadata": {
      "optional": false
    },
    "@stackra/ts-redis": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nesvel/tsup-config": "^1.0.3",
    "@nesvel/typescript-config": "^1.0.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "eslint": "10.2.0",
    "prettier": "^3.8.1",
    "@nesvel/eslint-config": "^1.0.5",
    "@nesvel/prettier-config": "^1.0.3",
    "@vitest/ui": "^4.1.2",
    "jsdom": "^29.0.1",
    "typescript-eslint": "^8.58.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "packageManager": "pnpm@10.33.0"
}
