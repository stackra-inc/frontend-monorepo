{
  "name": "@stackra/ts-realtime",
  "version": "1.0.1",
  "description": "Platform-agnostic Laravel Echo wrapper with DI module, typed channels, reconnection, and React hooks for real-time WebSocket communication",
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://github.com/stackra-inc"
  },
  "keywords": [
    "react",
    "realtime",
    "websocket",
    "laravel-echo",
    "pusher",
    "broadcasting",
    "channels",
    "dependency-injection",
    "di"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "config",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist node_modules/.cache",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm publish --access public --no-git-checks",
    "prepare": "husky"
  },
  "peerDependencies": {
    "@stackra/ts-container": "^2.0.12",
    "@stackra/ts-support": "^2.6.0",
    "laravel-echo": "^2.3.4",
    "pusher-js": "^8.5.0",
    "react": "^19.2.5"
  },
  "peerDependenciesMeta": {
    "laravel-echo": {
      "optional": false
    },
    "pusher-js": {
      "optional": false
    },
    "@stackra/ts-container": {
      "optional": false
    },
    "@stackra/ts-support": {
      "optional": false
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@stackra/eslint-config": "^1.0.9",
    "@stackra/prettier-config": "^1.0.7",
    "@stackra/tsup-config": "^1.0.9",
    "@stackra/typescript-config": "^1.0.10",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9.28.0",
    "eslint-plugin-turbo": "^2.9.6",
    "fast-check": "^4.7.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^29.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=22",
    "pnpm": ">=9.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "overrides": {
      "eslint": "^9.28.0",
      "@eslint/js": "^9.28.0",
      "vite": "^7.2.6"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stackra-inc/ts-realtime.git"
  },
  "bugs": {
    "url": "https://github.com/stackra-inc/ts-realtime/issues"
  },
  "homepage": "https://github.com/stackra-inc/ts-realtime#readme",
  "stackra": {
    "publish": {
      "config": {
        "source": "config/",
        "destination": "src/config/",
        "description": "Realtime WebSocket connections and driver configuration"
      },
      "steering": {
        "source": ".kiro/steering/",
        "destination": ".kiro/steering/{module}/",
        "description": "Kiro AI steering files for realtime"
      },
      "hooks": {
        "source": ".kiro/hooks/",
        "destination": ".kiro/hooks/",
        "description": "Kiro hooks"
      }
    }
  }
}
