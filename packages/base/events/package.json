{
  "name": "@stackra/ts-events",
  "version": "0.2.0",
  "description": "Laravel-style event dispatcher for TypeScript — pub/sub with wildcard listeners, subscribers, decorators, multiple drivers (memory, redis, null), and RxJS streaming.",
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://github.com/stackra-inc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stackra-inc/ts-events.git"
  },
  "homepage": "https://github.com/stackra-inc/ts-events#readme",
  "bugs": {
    "url": "https://github.com/stackra-inc/ts-events/issues"
  },
  "keywords": [
    "events",
    "event-dispatcher",
    "pub-sub",
    "laravel",
    "rxjs",
    "decorators",
    "dependency-injection",
    "typescript"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "config",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist node_modules/.cache",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm publish --access public --no-git-checks",
    "prepare": "husky"
  },
  "dependencies": {
    "@stackra/ts-container": "workspace:*",
    "@stackra/ts-redis": "workspace:*",
    "@stackra/ts-support": "workspace:*",
    "@vivtel/metadata": "^1.0.5",
    "rxjs": "^7.8.2"
  },
  "peerDependencies": {
    "@stackra/ts-container": "^2.0.12",
    "@stackra/ts-redis": "^1.1.9",
    "@stackra/ts-support": "^2.6.0",
    "react": "^19.2.5",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependenciesMeta": {
    "@stackra/ts-container": {
      "optional": false
    },
    "@stackra/ts-support": {
      "optional": false
    },
    "reflect-metadata": {
      "optional": false
    },
    "@stackra/ts-redis": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@stackra/eslint-config": "^1.0.9",
    "@stackra/prettier-config": "^1.0.7",
    "@stackra/tsup-config": "^1.0.9",
    "@stackra/typescript-config": "^1.0.10",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@vitest/ui": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-plugin-turbo": "^2.9.6",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^29.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.22.2",
    "pnpm": ">=10"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "packageManager": "pnpm@10.33.2",
  "stackra": {
    "publish": {
      "config": {
        "source": "config/",
        "destination": "src/config/",
        "description": "Event dispatchers, drivers, and wildcard settings"
      },
      "steering": {
        "source": ".kiro/steering/",
        "destination": ".kiro/steering/{module}/",
        "description": "Kiro AI steering files for events"
      },
      "hooks": {
        "source": ".kiro/hooks/",
        "destination": ".kiro/hooks/",
        "description": "Kiro hooks"
      }
    }
  }
}
