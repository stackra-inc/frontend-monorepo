{
  "name": "@abdokouta/ts-settings",
  "version": "1.0.1",
  "description": "Registry-based settings system with typed DTOs, JSON schema validation, and modular registration for React applications",
  "license": "MIT",
  "author": {
    "name": "Abdelrhman Kouta",
    "email": "abdelrhman@pixielity.com",
    "url": "https://github.com/abdokouta"
  },
  "keywords": [
    "react",
    "settings",
    "configuration",
    "registry",
    "dto",
    "validation",
    "dependency-injection",
    "di"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist node_modules/.cache",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "@abdokouta/ts-container": "workspace:*",
    "@abdokouta/ts-container-react": "workspace:*",
    "@abdokouta/ts-support": "workspace:*",
    "@abdokouta/ts-cache": "workspace:*",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@abdokouta/ts-container": {
      "optional": false
    },
    "@abdokouta/ts-support": {
      "optional": false
    },
    "@abdokouta/ts-container-react": {
      "optional": true
    },
    "@abdokouta/ts-cache": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nesvel/tsup-config": "^1.0.3",
    "@nesvel/typescript-config": "^1.0.4",
    "@types/react": "^19.2.14",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "sideEffects": false
}
