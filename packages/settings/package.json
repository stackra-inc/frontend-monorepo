{
  "name": "@stackra/ts-settings",
  "version": "1.0.1",
  "description": "Registry-based settings system with typed DTOs, JSON schema validation, and modular registration for React applications",
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://github.com/stackra-inc"
  },
  "keywords": [
    "react",
    "settings",
    "configuration",
    "registry",
    "dto",
    "validation",
    "dependency-injection",
    "di"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist node_modules/.cache",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm publish --access public --no-git-checks"
  },
  "peerDependencies": {
    "@stackra/ts-container": "^2.0.10",
    "@stackra/ts-support": "^2.5.7",
    "@stackra/ts-cache": "workspace:*",
    "@stackra/ts-realtime": "workspace:*",
    "react": "^19.2.5"
  },
  "peerDependenciesMeta": {
    "@stackra/ts-container": {
      "optional": false
    },
    "@stackra/ts-support": {
      "optional": false
    },
    "@stackra/ts-cache": {
      "optional": true
    },
    "@stackra/ts-realtime": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@stackra/tsup-config": "^1.0.4",
    "@stackra/typescript-config": "^1.0.5",
    "@types/react": "^19.2.14",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "eslint": "10.2.1",
    "prettier": "^3.8.3",
    "@stackra/eslint-config": "^1.0.6",
    "@stackra/prettier-config": "^1.0.4",
    "@vitest/ui": "^4.1.5",
    "jsdom": "^29.1.0",
    "typescript-eslint": "^8.59.0"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "packageManager": "pnpm@10.33.2"
}
