{
  "name": "@stackra/react-tracking",
  "version": "1.0.0",
  "description": "Browser engagement tracking, pixel management, and identity sync for React applications",
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://github.com/stackra-inc"
  },
  "keywords": [
    "react",
    "tracking",
    "analytics",
    "pixel",
    "meta",
    "google",
    "tiktok",
    "engagement",
    "page-view",
    "scroll-depth"
  ],
  "type": "module",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist node_modules/.cache",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "tslib": "^2.8.1",
    "@stackra/ts-support": "^2.5.7",
    "@stackra/ts-container": "^2.0.10",
    "@vivtel/metadata": "^1.0.5"
  },
  "devDependencies": {
    "@stackra/ts-http": "^1.0.0",
    "@stackra/ts-ui": "workspace:^",
    "@heroui/react": "^3.0.3",
    "@stackra/eslint-config": "^1.0.6",
    "@stackra/prettier-config": "^1.0.4",
    "@stackra/tsup-config": "^1.0.4",
    "@stackra/typescript-config": "^1.0.5",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "eslint": "10.2.1",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@stackra/ts-container": "^2.0.10",
    "@stackra/ts-http": "^1.0.0",
    "@stackra/ts-ui": "workspace:*",
    "@heroui/react": "^3.0.3",
    "react": "^19.2.5",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependenciesMeta": {
    "@stackra/ts-container": {
      "optional": false
    },
    "@stackra/ts-http": {
      "optional": false
    },
    "@stackra/ts-ui": {
      "optional": true
    },
    "@heroui/react": {
      "optional": true
    },
    "reflect-metadata": {
      "optional": false
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "packageManager": "pnpm@10.33.2"
}
