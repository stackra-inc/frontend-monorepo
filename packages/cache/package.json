{
  "name": "@abdokouta/react-cache",
  "version": "1.2.1",
  "description": "Laravel-inspired caching system with multiple drivers (Memory, Redis, Null) for React",
  "license": "MIT",
  "author": {
    "name": "Abdelrhman Kouta",
    "email": "abdelrhman@pixielity.com",
    "url": "https://github.com/abdokouta"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/abdokouta/cache.git",
    "directory": "packages/cache"
  },
  "bugs": {
    "url": "https://github.com/abdokouta/cache/issues"
  },
  "homepage": "https://github.com/abdokouta/cache#readme",
  "keywords": [
    "react",
    "cache",
    "redis",
    "laravel",
    "tagging",
    "memory-cache",
    "upstash",
    "dependency-injection",
    "di"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "config",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist node_modules/.cache",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm publish --access public --no-git-checks"
  },
  "dependencies": {
    "@upstash/redis": "^1.37.0"
  },
  "peerDependencies": {
    "@abdokouta/ts-container": "^1.2.0",
    "@abdokouta/ts-container-react": "^1.2.0",
    "@abdokouta/react-support": "^2.1.0",
    "@abdokouta/react-redis": "^1.1.2",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@abdokouta/ts-container": {
      "optional": false
    },
    "@abdokouta/react-support": {
      "optional": false
    },
    "@abdokouta/ts-container-react": {
      "optional": true
    },
    "@abdokouta/react-redis": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.2.0",
    "@nesvel/eslint-config": "^1.0.5",
    "@nesvel/prettier-config": "^1.0.3",
    "@nesvel/tsup-config": "^1.0.3",
    "@nesvel/typescript-config": "^1.0.4",
    "@types/react": "^19.2.14",
    "@vitest/ui": "^4.1.2",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "sideEffects": false
}
