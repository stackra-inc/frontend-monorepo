{
  "name": "@stackra/react-i18n",
  "version": "1.0.0",
  "description": "Comprehensive i18n Vite plugin with i18next integration, auto-file-globbing, type generation, and Refine provider support",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./vite-plugin": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.mjs",
      "require": "./dist/adapters/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.mjs",
      "require": "./dist/providers/index.js"
    },
    "./types": "./@types/virtual-module.d.ts",
    "./types/globals": "./@types/globals.d.ts",
    "./@types": "./@types/virtual-module.d.ts",
    "./@types/globals": "./@types/globals.d.ts"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "i18n",
    "i18next",
    "vite",
    "plugin",
    "vite-plugin",
    "translation",
    "internationalization",
    "refine",
    "react-i18next",
    "auto-globbing",
    "type-safe",
    "zero-import"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "@types",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "vite": "^8.0.10",
    "@stackra/ts-container": "^2.0.10",
    "@stackra/ts-http": "^1.0.0"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.6",
    "react-i18next": "^17.0.4",
    "@stackra/ts-support": "^2.5.7"
  },
  "devDependencies": {
    "@stackra/eslint-config": "^1.0.6",
    "@stackra/tsup-config": "^1.0.4",
    "@stackra/typescript-config": "^1.0.5",
    "@refinedev/core": "^5.0.12",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.2.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "peerDependenciesMeta": {
    "@stackra/ts-container": {
      "optional": false
    },
    "@stackra/ts-http": {
      "optional": true
    },
    "vite": {
      "optional": false
    }
  },
  "packageManager": "pnpm@10.33.0"
}
