{
  "name": "@stackra/ts-config",
  "version": "1.0.3",
  "description": "Multi-source configuration management with multiple drivers (Env, File, HTTP) and DI integration",
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://github.com/stackra-inc"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stackra-inc/config.git",
    "directory": "packages/config"
  },
  "bugs": {
    "url": "https://github.com/stackra-inc/config/issues"
  },
  "homepage": "https://github.com/stackra-inc/config#readme",
  "keywords": [
    "react",
    "config",
    "configuration",
    "environment",
    "nestjs",
    "env",
    "dotenv",
    "dependency-injection",
    "di"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vite-plugin": {
      "types": "./dist/vite-plugin.d.ts",
      "import": "./dist/vite-plugin.js",
      "require": "./dist/vite-plugin.cjs"
    },
    "./client": {
      "types": "./@types/virtual-module.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "@types",
    "config",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist node_modules/.cache",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm publish --access public --no-git-checks"
  },
  "peerDependencies": {
    "@stackra/ts-container": "^2.0.10",
    "@stackra/ts-support": "^2.5.7",
    "@stackra/ts-http": "^1.0.0",
    "fast-glob": "^3.3.3",
    "vite": "^8.0.10"
  },
  "peerDependenciesMeta": {
    "@stackra/ts-container": {
      "optional": false
    },
    "@stackra/ts-support": {
      "optional": false
    },
    "@stackra/ts-http": {
      "optional": true
    },
    "fast-glob": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@stackra/eslint-config": "^1.0.6",
    "@stackra/prettier-config": "^1.0.4",
    "@stackra/tsup-config": "^1.0.4",
    "@stackra/typescript-config": "^1.0.5",
    "@types/node": "^25.6.0",
    "@vitest/ui": "^4.1.5",
    "dotenv": "^17.4.2",
    "jsdom": "^29.1.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "eslint": "10.2.1"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "sideEffects": false,
  "packageManager": "pnpm@10.33.0"
}
