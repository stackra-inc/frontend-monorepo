{
  "name": "@stackra/vite-decorator-discovery",
  "version": "1.0.0",
  "description": "Vite plugin for build-time decorator discovery and virtual module generation. Inspired by NestJS DiscoveryService.",
  "keywords": [
    "vite",
    "plugin",
    "decorator",
    "discovery",
    "typescript",
    "nestjs",
    "virtual-module",
    "build-time",
    "compile-time"
  ],
  "license": "MIT",
  "author": "stackra-inc",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./@types": {
      "types": "./@types/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "@types",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm publish --access public --no-git-checks"
  },
  "dependencies": {
    "glob": "^13.0.6",
    "typescript": "^6.0.3",
    "@stackra/ts-support": "^2.5.7"
  },
  "peerDependencies": {
    "vite": "^8.0.10"
  },
  "devDependencies": {
    "@stackra/eslint-config": "^1.0.6",
    "@stackra/prettier-config": "^1.0.4",
    "@stackra/tsup-config": "^1.0.4",
    "@stackra/typescript-config": "^1.0.5",
    "@types/node": "^25.6.0",
    "@vitest/ui": "^4.1.5",
    "eslint": "10.2.1",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.0"
}
