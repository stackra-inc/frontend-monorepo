{
  "name": "@stackra/react-router",
  "version": "1.0.0",
  "description": "Route auto-registration package with @Route decorator and RouteRegistry for @stackra/react-refine.",
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://github.com/stackra-inc"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stackra-inc/frontend-monorepo.git",
    "directory": "packages/router"
  },
  "keywords": [
    "react",
    "router",
    "route",
    "decorator",
    "auto-registration",
    "dependency-injection"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist node_modules/.cache",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm publish --access public --no-git-checks"
  },
  "dependencies": {
    "tslib": "^2.8.1",
    "@stackra/ts-support": "^2.5.7",
    "@stackra/ts-container": "^2.0.10"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "10.2.1",
    "jsdom": "^29.1.0",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "@stackra/typescript-config": "^1.0.5",
    "@stackra/tsup-config": "^1.0.4",
    "@stackra/eslint-config": "^1.0.6",
    "@stackra/prettier-config": "^1.0.4",
    "@vitest/ui": "^4.1.5",
    "typescript-eslint": "^8.59.0"
  },
  "peerDependencies": {
    "@stackra/react-refine": "workspace:*",
    "@stackra/ts-container": "^2.0.10",
    "@stackra/ts-support": "^2.5.7",
    "react-router-dom": "^7.14.2",
    "react": "^19.2.5",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependenciesMeta": {
    "@stackra/react-refine": {
      "optional": false
    },
    "@stackra/ts-container": {
      "optional": false
    },
    "react-router-dom": {
      "optional": false
    },
    "reflect-metadata": {
      "optional": false
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "packageManager": "pnpm@10.33.0"
}
