{
  "name": "@stakra/react-refine",
  "version": "1.0.2",
  "description": "Refine Framework integration with dependency injection for React applications",
  "license": "MIT",
  "author": {
    "name": "Stakra L.L.C",
    "email": "dev@stakra.com",
    "url": "https://github.com/stakra"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stakra/react-refine.git",
    "directory": "packages/refine"
  },
  "bugs": {
    "url": "https://github.com/stakra/react-refine/issues"
  },
  "homepage": "https://github.com/stakra/react-refine#readme",
  "keywords": [
    "react",
    "refine",
    "data-provider",
    "crud",
    "admin",
    "dependency-injection",
    "di",
    "hooks"
  ],
  "type": "module",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist node_modules/.cache",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm publish --access public --no-git-checks"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@stakra/ts-cache": "workspace:^",
    "@stakra/ts-events": "workspace:^",
    "@stakra/ts-http": "workspace:^",
    "@nesvel/eslint-config": "^1.0.5",
    "@nesvel/prettier-config": "^1.0.3",
    "@nesvel/tsup-config": "^1.0.3",
    "@nesvel/typescript-config": "^1.0.4",
    "@tanstack/react-query": "^5.96.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "@heroui/react": "^3.0.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "eslint": "10.2.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@stakra/ts-eloquent": "workspace:*",
    "@stakra/ts-cache": "workspace:*",
    "@stakra/ts-container": "workspace:*",
    "@stakra/ts-events": "workspace:*",
    "@stakra/ts-http": "workspace:*",
    "@stakra/ts-redis": "workspace:*",
    "@stakra/ts-support": "workspace:*",
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "reflect-metadata": "^0.2.2",
    "@heroui/react": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@heroui/react": {
      "optional": false
    },
    "@stakra/ts-container": {
      "optional": false
    },
    "@stakra/ts-http": {
      "optional": false
    },
    "@stakra/ts-cache": {
      "optional": true
    },
    "@stakra/ts-eloquent": {
      "optional": true
    },
    "@stakra/ts-events": {
      "optional": true
    },
    "@stakra/ts-redis": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": false
    },
    "reflect-metadata": {
      "optional": false
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "sideEffects": false,
  "packageManager": "pnpm@10.33.0"
}
