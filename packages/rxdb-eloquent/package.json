{
  "name": "@stackra/ts-eloquent",
  "version": "1.2.1",
  "description": "Laravel Eloquent-style TypeScript ORM built on RxDB — reactive, offline-first, with Supabase replication",
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://github.com/stackra-inc"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stackra-inc/rxdb-eloquent.git",
    "directory": "packages/rxdb-eloquent"
  },
  "bugs": {
    "url": "https://github.com/stackra-inc/rxdb-eloquent/issues"
  },
  "homepage": "https://github.com/stackra-inc/rxdb-eloquent#readme",
  "keywords": [
    "rxdb",
    "eloquent",
    "orm",
    "typescript",
    "reactive",
    "offline-first",
    "indexeddb",
    "supabase",
    "replication",
    "laravel",
    "model",
    "query-builder",
    "decorator",
    "dependency-injection"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "config",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist node_modules/.cache",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm publish --access public --no-git-checks"
  },
  "peerDependencies": {
    "@stackra/ts-support": "workspace:*",
    "@stackra/ts-container": "^2.0.4",
    "@stackra/ts-logger": "workspace:*",
    "@supabase/supabase-js": "^2.0.0",
    "rxdb": "^17.1.0",
    "rxjs": "^7.8.2"
  },
  "peerDependenciesMeta": {
    "@stackra/ts-container": {
      "optional": false
    },
    "@stackra/ts-support": {
      "optional": false
    },
    "@supabase/supabase-js": {
      "optional": true
    },
    "@stackra/ts-logger": {
      "optional": true
    },
    "rxdb": {
      "optional": false
    },
    "rxjs": {
      "optional": false
    }
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@nesvel/eslint-config": "^1.0.5",
    "@nesvel/prettier-config": "^1.0.3",
    "@nesvel/tsup-config": "^1.0.3",
    "@nesvel/typescript-config": "^1.0.4",
    "@supabase/supabase-js": "^2.102.0",
    "@types/react": "^19.2.14",
    "@vitest/ui": "^4.1.2",
    "eslint": "10.2.0",
    "fast-check": "^4.6.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "sideEffects": false,
  "packageManager": "pnpm@10.33.0"
}
