{
  "name": "@abdokouta/react-theming",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "description": "Theme customizer registry and UI for the MNGO platform",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "check-types": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm publish --access public --no-git-checks"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "@abdokouta/ts-ui": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@abdokouta/ts-ui": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "eslint": "10.2.0",
    "prettier": "^3.8.1",
    "@nesvel/typescript-config": "^1.0.4",
    "@nesvel/tsup-config": "^1.0.3",
    "@nesvel/eslint-config": "^1.0.5",
    "@nesvel/prettier-config": "^1.0.3",
    "@vitest/ui": "^4.1.2",
    "jsdom": "^29.0.1",
    "typescript-eslint": "^8.58.0"
  },
  "dependencies": {
    "@abdokouta/react-support": "^1.1.0",
    "@abdokouta/ts-container": "workspace:*",
    "@heroui/react": "^3.0.1",
    "inversiland": "^0.6.2",
    "next-themes": "^0.4.6",
    "reflect-metadata": "^0.2.2"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
