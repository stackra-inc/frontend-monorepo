# ==============================================================================
# Vite — Staging Environment
# ==============================================================================
# Staging configuration — production-like, pointed at staging APIs.
# Analytics enabled at 10% sampling.
# ==============================================================================


# ==============================================================================
# APPLICATION
# ==============================================================================

VITE_APP_NAME=Stackra Staging
VITE_APP_VERSION=0.0.1
VITE_APP_ENV=staging
NODE_ENV=production


# ==============================================================================
# API
# ==============================================================================

VITE_API_BASE_URL=https://staging-api.stackra.com
VITE_API_VERSION=v1
VITE_API_TIMEOUT_MS=30000
VITE_API_MAX_RETRIES=3


# ==============================================================================
# AUTHENTICATION
# ==============================================================================

VITE_AUTH_STRATEGY=jwt
VITE_AUTH_OAUTH2_CLIENT_ID=
VITE_AUTH_OAUTH2_REDIRECT_URI=https://staging.stackra.com/auth/callback
VITE_AUTH_OAUTH2_AUTH_ENDPOINT=
VITE_AUTH_OAUTH2_TOKEN_ENDPOINT=
VITE_AUTH_OAUTH2_SCOPES=openid,profile,email
VITE_AUTH_SESSION_TIMEOUT_S=86400


# ==============================================================================
# ANALYTICS
# ==============================================================================

VITE_ANALYTICS_ENABLED=true
VITE_ANALYTICS_CRASH_ENABLED=true
VITE_ANALYTICS_GA_MEASUREMENT_ID=
VITE_ANALYTICS_MIXPANEL_TOKEN=
VITE_ANALYTICS_AMPLITUDE_API_KEY=
VITE_ANALYTICS_SEGMENT_WRITE_KEY=
VITE_ANALYTICS_POSTHOG_API_KEY=
VITE_ANALYTICS_POSTHOG_HOST=https://app.posthog.com
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1


# ==============================================================================
# FEATURE FLAGS
# ==============================================================================

VITE_FLAG_NEW_ONBOARDING=true
VITE_FLAG_AI_ASSISTANT=false
VITE_FLAG_PREMIUM_THEMES=false
VITE_FLAG_NEW_DASHBOARD=false
VITE_FLAGS_REMOTE_PROVIDER=none
VITE_FLAGS_REMOTE_SDK_KEY=
VITE_FLAGS_REMOTE_ENDPOINT=


# ==============================================================================
# WEBSOCKETS / REALTIME
# ==============================================================================

VITE_WS_ENABLED=false
VITE_WS_URL=wss://staging-ws.stackra.com
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=staging-ws.stackra.com
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=wss


# ==============================================================================
# STORAGE
# ==============================================================================

VITE_STORAGE_KEY_PREFIX=stackra-inc_staging


# ==============================================================================
# LOGGING
# ==============================================================================

VITE_LOG_LEVEL=info
VITE_LOG_REMOTE_ENDPOINT=
VITE_LOG_REMOTE_API_KEY=
