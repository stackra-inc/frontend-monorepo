{
  "name": "@stackra/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Stackra Desktop — Electron shell wrapping the Vite app",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com"
  },
  "license": "MIT",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k -n vite,electron \"pnpm --filter @stackra/vite dev\" \"wait-on http://localhost:5173 && electron .\"",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build": "pnpm --filter @stackra/vite build && pnpm build:main && pnpm build:preload",
    "package": "pnpm build && electron-builder",
    "package:mac": "pnpm build && electron-builder --mac",
    "package:win": "pnpm build && electron-builder --win",
    "package:linux": "pnpm build && electron-builder --linux",
    "package:all": "pnpm build && electron-builder --mac --win --linux",
    "clean": "rm -rf dist release",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit"
  },
  "dependencies": {
    "@stackra/ts-desktop": "workspace:*"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "concurrently": "^9.1.0",
    "wait-on": "^8.0.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@10.33.0"
}
