<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required for hardened runtime -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Network access (for API calls, auto-update) -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Camera access (for POS barcode scanning via camera) -->
    <key>com.apple.security.device.camera</key>
    <true/>

    <!-- Microphone access (for voice commands if needed) -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- USB access (for POS hardware: printers, scales, drawers) -->
    <key>com.apple.security.device.usb</key>
    <true/>

    <!-- Serial port access (for POS hardware) -->
    <key>com.apple.security.device.serial</key>
    <true/>

    <!-- Bluetooth access (for POS peripherals) -->
    <key>com.apple.security.device.bluetooth</key>
    <true/>

    <!-- Keychain access (for secure credential storage) -->
    <key>com.apple.security.keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)com.pixielity.desktop</string>
    </array>
</dict>
</plist>
