# ==============================================================================
# Next.js Application Configuration
# ==============================================================================
# This file documents every environment variable accepted by the Next.js app.
# Copy this file to .env.development.local, .env.staging.local, or
# .env.production.local and fill in the values for each environment.
#
# Next.js variable visibility rules:
#   - NEXT_PUBLIC_* variables are inlined into the browser bundle at build time.
#     They are PUBLIC — never put secrets in NEXT_PUBLIC_ variables.
#   - Variables WITHOUT the NEXT_PUBLIC_ prefix are server-side only.
#     They are available in API routes, getServerSideProps, and Server Components.
#
# File loading order (highest priority first):
#   .env.$(NODE_ENV).local  →  .env.local  →  .env.$(NODE_ENV)  →  .env
#
# NEVER commit .env.*.local files to git — they contain secrets.
# Only .env.example is tracked.
# ==============================================================================


# ==============================================================================
# APPLICATION
# ==============================================================================

NEXT_PUBLIC_APP_NAME=Pixielity
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_APP_ENV=development

# Node environment — controls Next.js build optimisations.
# Supported: development | test | production
NODE_ENV=development


# ==============================================================================
# API
# ==============================================================================

# Public API base URL — exposed to the browser for client-side fetching.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_API_VERSION=v1
NEXT_PUBLIC_API_TIMEOUT_MS=30000

# Internal API base URL — used by server-side code only (SSR, API routes).
# Can point to an internal network address not accessible from the browser.
API_INTERNAL_BASE_URL=http://localhost:8080

# Server-side API secret key — NEVER use NEXT_PUBLIC_ for this.
API_SECRET_KEY=


# ==============================================================================
# AUTHENTICATION
# ==============================================================================

# Supported: jwt | oauth2 | nextauth | none
NEXT_PUBLIC_AUTH_STRATEGY=jwt

# NextAuth.js configuration (only required when NEXT_PUBLIC_AUTH_STRATEGY=nextauth)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# OAuth2 / OIDC provider (server-side — no NEXT_PUBLIC_ prefix)
AUTH_OAUTH2_CLIENT_ID=
AUTH_OAUTH2_CLIENT_SECRET=
AUTH_OAUTH2_ISSUER=
AUTH_OAUTH2_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Session timeout in seconds.
NEXT_PUBLIC_AUTH_SESSION_TIMEOUT_S=86400


# ==============================================================================
# DATABASE (server-side only)
# ==============================================================================

DATABASE_URL=postgresql://user:password@localhost:5432/pixielity
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10


# ==============================================================================
# REDIS (server-side only)
# ==============================================================================

REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0


# ==============================================================================
# UPSTASH REDIS (HTTP — works in browser)
# ==============================================================================

NEXT_PUBLIC_UPSTASH_REDIS_REST_URL=
NEXT_PUBLIC_UPSTASH_REDIS_REST_TOKEN=


# ==============================================================================
# ANALYTICS
# ==============================================================================

NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_ANALYTICS_CRASH_ENABLED=false

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Mixpanel
NEXT_PUBLIC_MIXPANEL_TOKEN=

# PostHog
NEXT_PUBLIC_POSTHOG_API_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry — DSN is public (used in browser), auth token is server-side only.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1


# ==============================================================================
# FEATURE FLAGS
# ==============================================================================

NEXT_PUBLIC_FLAG_NEW_ONBOARDING=false
NEXT_PUBLIC_FLAG_AI_ASSISTANT=false
NEXT_PUBLIC_FLAG_PREMIUM_THEMES=false
NEXT_PUBLIC_FLAG_NEW_DASHBOARD=false

# Remote feature flag provider
# Supported: none | launchDarkly | unleash | posthog | custom
NEXT_PUBLIC_FLAGS_REMOTE_PROVIDER=none
# Server-side SDK key — do NOT use NEXT_PUBLIC_ for this.
FLAGS_REMOTE_SDK_KEY=
NEXT_PUBLIC_FLAGS_REMOTE_ENDPOINT=


# ==============================================================================
# WEBSOCKETS / REALTIME
# ==============================================================================

NEXT_PUBLIC_WS_ENABLED=false
NEXT_PUBLIC_WS_URL=ws://localhost:6001

# Laravel Reverb / Pusher
NEXT_PUBLIC_REVERB_APP_KEY=
NEXT_PUBLIC_REVERB_HOST=localhost
NEXT_PUBLIC_REVERB_PORT=6001
NEXT_PUBLIC_REVERB_SCHEME=ws


# ==============================================================================
# STORAGE / CDN
# ==============================================================================

# Public CDN base URL for static assets.
NEXT_PUBLIC_CDN_URL=

# S3 / object storage (server-side only).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=


# ==============================================================================
# MAIL (server-side only)
# ==============================================================================

MAIL_FROM_ADDRESS=noreply@pixielity.com
MAIL_FROM_NAME=Pixielity
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=


# ==============================================================================
# LOGGING
# ==============================================================================

# Supported: verbose | debug | info | warning | error | none
NEXT_PUBLIC_LOG_LEVEL=verbose

# Remote log endpoint (server-side — keep API key out of NEXT_PUBLIC_).
LOG_REMOTE_ENDPOINT=
LOG_REMOTE_API_KEY=


# ==============================================================================
# THIRD-PARTY SERVICES
# ==============================================================================

# Add your third-party service keys here.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=
